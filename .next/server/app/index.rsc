6:["$","section",null,{"className":"border-t border-line bg-ink","children":["$","div",null,{"className":"mx-auto max-w-page px-6 py-16 sm:py-20","children":[["$","p",null,{"className":"label-eyebrow mb-8 text-amber","children":"Operating principles"}],["$","div",null,{"className":"grid gap-10 sm:grid-cols-2","children":[["$","div","Systems over heroics",{"children":[["$","h3",null,{"className":"font-display text-xl text-paper","children":"Systems over heroics"}],["$","p",null,{"className":"mt-2 text-paper/65 leading-relaxed","children":"A team that depends on one brilliant save is one bad week from falling over. I build the process, critique culture, and tooling so good work is the default outcome, not the exception."}]]}],["$","div","Design is a P&L lever",{"children":[["$","h3",null,{"className":"font-display text-xl text-paper","children":"Design is a P&L lever"}],["$","p",null,{"className":"mt-2 text-paper/65 leading-relaxed","children":"I translate craft into the language a business actually moves on: velocity, retention, cost of rework. If a design decision can't be argued in those terms, I keep working until it can."}]]}],["$","div","Hire for trajectory, not résumé",{"children":[["$","h3",null,{"className":"font-display text-xl text-paper","children":"Hire for trajectory, not résumé"}],["$","p",null,{"className":"mt-2 text-paper/65 leading-relaxed","children":"The best designers I've grown weren't the most polished on day one. I look for people who improve fast in public, then build the room that lets them."}]]}],["$","div","Ship the smallest true thing",{"children":[["$","h3",null,{"className":"font-display text-xl text-paper","children":"Ship the smallest true thing"}],["$","p",null,{"className":"mt-2 text-paper/65 leading-relaxed","children":"Strategy decks don't ship. I push every initiative toward the smallest version that proves the idea in production, then scale what's working."}]]}]]}]]}]}]
